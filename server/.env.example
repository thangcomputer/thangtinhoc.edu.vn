# Database (SQLite dev — dùng PostgreSQL cho production)
DATABASE_URL="file:./dev.db"

# Bắt buộc — chuỗi ngẫu nhiên dài (openssl rand -base64 48)
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRE=7d

NODE_ENV=development
PORT=5000

# CORS: client + admin + preview merged (phân tách bằng dấu phẩy)
# Dev: mọi localhost/127.0.0.1 vẫn được phép tự động
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:4288,http://localhost:4288

# URL website công khai (reset mật khẩu, link ảnh upload — BẮT BUỘC trên VPS)
# Production: https://thangtinhoc.edu.vn  (không dùng 127.0.0.1)
SITE_URL=http://localhost:5173

# Google OAuth (bắt buộc production nếu dùng đăng nhập Google)
GOOGLE_CLIENT_ID=

# Email — Resend (https://resend.com) — BẮT BUỘC cho quên mật khẩu / xác nhận đơn hàng
# Tạo API key → verify domain thangtinhoc.vn → dùng EMAIL_FROM dưới đây
# Dev không verify domain: dùng onboarding@resend.dev, chỉ gửi được tới email tài khoản Resend
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Thắng Tin Học <noreply@thangtinhoc.vn>

# AI tạo bài viết (admin) — ít nhất 1 key, đều MIỄN PHÍ:
# Gemini: https://aistudio.google.com/apikey
# Groq:   https://console.groq.com/keys  (khuyên dùng — quota rộng hơn)
GEMINI_API_KEY=
GROQ_API_KEY=
# Tùy chọn — Google Custom Search bổ sung dữ liệu
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=

# Upload
MAX_FILE_SIZE=104857600

# Production only: bật thanh toán demo (mặc định TẮT)
# ALLOW_MOCK_PAYMENT=false
