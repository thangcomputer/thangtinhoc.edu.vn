# Database provider: "sqlite" cho local dev, "postgresql" cho production
DATABASE_PROVIDER=sqlite
DATABASE_URL="file:./dev.db"

# Production PostgreSQL (Render/Supabase/Neon - thay thế 2 dòng trên khi deploy)
# DATABASE_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Bắt buộc — chuỗi ngẫu nhiên dài (openssl rand -base64 48)
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRE=7d

NODE_ENV=development
PORT=5000

# CORS: client + admin + preview merged (phân tách bằng dấu phẩy)
# Dev: mọi localhost/127.0.0.1 vẫn được phép tự động
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://127.0.0.1:4288,http://localhost:4288

# URL website công khai (reset mật khẩu, link ảnh upload — BẮT BUỘC trên VPS)
# Production: https://thangtinhoc.edu.vn  (không dùng 127.0.0.1)
SITE_URL=http://localhost:5173

# URL trang admin (dùng trong email thông báo cho admin)
# Production: https://tinhoc24h.netlify.app/admin
ADMIN_URL=http://localhost:5174

# Email admin nhận thông báo đăng ký mới / đơn hàng
EMAIL_USER=admin@yourdomain.com

# Idle session timeout (phút) — mặc định 60
# SESSION_IDLE_MINUTES=60

# Server có serve frontend không (true = VPS, false = Netlify/Render riêng)
SERVE_FRONTEND=false

# Google OAuth (bắt buộc production nếu dùng đăng nhập Google)
GOOGLE_CLIENT_ID=

# Email — Resend (https://resend.com) — BẮT BUỘC cho quên mật khẩu / xác nhận đơn hàng
# Tạo API key → verify domain thangtinhoc.vn → dùng EMAIL_FROM dưới đây
# Dev không verify domain: dùng onboarding@resend.dev, chỉ gửi được tới email tài khoản Resend
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Thắng Tin Học <noreply@thangtinhoc.vn>

# CTA cuối bài AI — Copywriter Master (mặc định: Zalo Cô Nga)
# ZALO_CTA_TEXT=Nhắn tin Zalo Cô Nga để được tư vấn lộ trình và xếp lớp nhanh nhất.

# AI tạo bài viết (admin) — ít nhất 1 key, đều MIỄN PHÍ:
# Gemini: https://aistudio.google.com/apikey
# Groq:   https://console.groq.com/keys  (khuyên dùng — quota rộng hơn)
GEMINI_API_KEY=
GROQ_API_KEY=
# Tùy chọn — Google Custom Search bổ sung dữ liệu
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=

# Upload
MAX_FILE_SIZE=104857600

# Cloudinary — lưu ảnh vĩnh viễn trên cloud (BẮT BUỘC trên Render/Netlify để ảnh không bị mất)
# Đăng ký miễn phí tại: https://cloudinary.com → Dashboard → sao chép 3 giá trị này
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production only: bật thanh toán demo (mặc định TẮT)
# ALLOW_MOCK_PAYMENT=false
