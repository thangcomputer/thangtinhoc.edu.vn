# Copy to site_dist/.htaccess after npm run build:merged
# aaPanel: Website root = .../site_dist, enable rewrite module

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Admin panel SPA (/admin/login, /admin/courses, ...)
  RewriteRule ^admin/login$ /admin/index.html [L]
  RewriteCond %{REQUEST_URI} ^/admin(/|$)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^admin(/.*)?$ /admin/index.html [L]

  # API / uploads / SEO — Apache proxy xu ly (khong rewrite ve index.html)
  RewriteCond %{REQUEST_URI} ^/api [OR]
  RewriteCond %{REQUEST_URI} ^/uploads [OR]
  RewriteCond %{REQUEST_URI} ^/sitemap\.xml$ [OR]
  RewriteCond %{REQUEST_URI} ^/robots\.txt$
  RewriteRule ^ - [L]

  # Blog SPA — thu muc /blog/ (anh post) trung route React /blog
  # Khong co rule nay: Apache thay /blog/ la folder -> 403 Forbidden
  RewriteRule ^blog/?$ /index.html [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^blog/.+ /index.html [L]

  # Public site SPA
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ /index.html [L]

</IfModule>